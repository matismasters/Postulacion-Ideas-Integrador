# Copiar a .env y rellenar. No commitear el .env real.
#
# Cuando corrés `docker compose up`, compose sustituye las variables en el yaml
# y también pasa el archivo como env_file a los containers (app y db).

# ==============================================================================
# PostgreSQL dedicado a postulacion-ideas (servicio `db` del compose)
# ==============================================================================
POSTGRES_USER=postulacion
POSTGRES_PASSWORD=
POSTGRES_DB=integradorideas

# ==============================================================================
# Connection string que usa la app. Program.cs lee DATABASE_URL en formato URI
# (postgres://user:password@host:port/database) y la parsea. El host es el
# service `db` del compose (misma red `default`).
# Tiene que coincidir con POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB de arriba.
# Ejemplo: postgres://postulacion:TU_PASSWORD@db:5432/integradorideas
# ==============================================================================
DATABASE_URL=

# ==============================================================================
# Hostname Traefik (default staging: postulacion-ideas.codice.uy)
# Prod: postulacion-ideas.prod.codice.uy
# ==============================================================================
# POSTULACION_IDEAS_HOST=postulacion-ideas.prod.codice.uy
