@model IntegradorIdeas.ViewModels.PostIdeaViewModel

@{
    ViewData["Title"] = "Postular Idea";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white text-center py-3">
                <h4 class="mb-0"><i class="bi bi-lightbulb-fill me-2"></i>Postular Idea Creativa</h4>
            </div>
            <div class="card-body p-4 bg-light">
                
                <form asp-action="Post" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="TeamName" class="form-label fw-bold"></label>
                            <input asp-for="TeamName" class="form-control" placeholder="Nombre completo de su equipo" />
                            <span asp-validation-for="TeamName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TeamPassword" class="form-label fw-bold"></label>
                            <input asp-for="TeamPassword" class="form-control" placeholder="Contraseña de registro" />
                            <span asp-validation-for="TeamPassword" class="text-danger small"></span>
                        </div>
                        <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i>Debe ingresar los datos de su equipo para autenticarse y enviar la idea.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Text" class="form-label fw-bold"></label>
                        <textarea asp-for="Text" class="form-control" rows="6" placeholder="Describa su idea creativa en detalle..."></textarea>
                        <span asp-validation-for="Text" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Postular Idea</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
