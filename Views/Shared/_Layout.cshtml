<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IntegradorIdeas</title>
    <!-- Muted, slate-like bootstrap theme approach -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IntegradorIdeas.styles.css" asp-append-version="true" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
        }
        body {
            /* Academic look - slight gray/slate tint */
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .navbar-custom, .footer-custom {
            background-color: #1e293b; /* Slate 800 */
        }
        .footer-custom {
            color: #cbd5e1; /* Slate 300 */
            margin-top: auto;
        }
        .footer-custom a {
            color: #94a3b8;
            text-decoration: none;
            transition: color 0.2s;
        }
        .footer-custom a:hover {
            color: #f8fafc;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark navbar-custom border-bottom box-shadow mb-3 pb-2 pt-2 shadow-sm">
            <div class="container d-flex justify-content-between">
                <div>
                    <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-mortarboard-fill me-2 bg-primary rounded px-2 py-1"></i>Integrador Ideas
                    </a>
                </div>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-1"></i>Inicio</a>
                        </li>
                        
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item ms-2">
                                <a class="nav-link text-warning fw-bold" asp-controller="Professor" asp-action="Index"><i class="bi bi-shield-lock-fill me-1"></i>Panel Profesor</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-sm btn-outline-light" asp-controller="Professor" asp-action="Logout"><i class="bi bi-box-arrow-right me-1"></i>Salir</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-3">
                                <a class="nav-link text-white opacity-75 small" asp-area="" asp-controller="Professor" asp-action="Login"><i class="bi bi-lock-fill me-1"></i>Acceso Profesores</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container flex-grow-1">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom py-5 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-12 col-md-4">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-mortarboard-fill me-2 text-primary"></i>Integrador Ideas</h5>
                    <p class="small">Plataforma dedicada a la gestión y validación de proyectos académicos innovadores. Impulsando la creatividad y el rigor técnico en la educación superior.</p>
                </div>
                <div class="col-6 col-md-4">
                    <h6 class="text-white fw-bold mb-3">Enlaces Rápidos</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                        <li class="mb-2"><a asp-controller="Team" asp-action="Register">Registrar Equipo</a></li>
                        <li class="mb-2"><a asp-controller="Idea" asp-action="Post">Postular Nueva Idea</a></li>
                    </ul>
                </div>
                <div class="col-6 col-md-4">
                    <h6 class="text-white fw-bold mb-3">Recursos</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#">Guía de Usuario</a></li>
                        <li class="mb-2"><a href="#">Criterios de Evaluación</a></li>
                        <li class="mb-2"><a asp-controller="Professor" asp-action="Login">Acceso Administrativo</a></li>
                    </ul>
                </div>
            </div>
            <hr class="my-4 border-secondary opacity-25">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <span class="small">&copy; 2026 - Integrador Ideas - Todos los derechos reservados</span>
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <a href="#" class="me-3"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="me-3"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" class="me-3"><i class="bi bi-linkedin"></i></a>
                    <a href="#"><i class="bi bi-github"></i></a>
                </div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
